{
  "name": "table-view",
  "displayName": "Table View",
  "description": "View 2D arrays in Table format",
  "version": "0.0.7",
  "publisher": "gsingh704",
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Debuggers",
    "Visualization",
    "Data Science"
  ],
  "keywords": [
    "table",
    "grid",
    "data",
    "visualization",
    "debug",
    "chart",
    "csv",
    "json",
    "array",
    "object",
    "inspect",
    "viewer"
  ],
  "author": {
    "name": "Gurjant Singh",
    "email": "gurjant.dev@gmail.com",
    "url": "https://gurjant.fyi"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gsingh704/table-view"
  },
  "icon": "img/icon.png",
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "table-view.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "table-view.viewAsTable",
        "title": "View as Table",
        "icon": "$(table)"
      },
      {
        "command": "tableView.clearVariables",
        "title": "Clear All",
        "icon": "$(trash)"
      },
      {
        "command": "tableView.saveVariables",
        "title": "Save Variables",
        "icon": "$(save)"
      },
      {
        "command": "tableView.openSettings",
        "title": "Open Settings",
        "icon": "$(settings-gear)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "tableView.openSettings",
          "when": "view == tableView.variablesView",
          "group": "navigation@1"
        },
        {
          "command": "tableView.saveVariables",
          "when": "view == tableView.variablesView",
          "group": "navigation@2"
        },
        {
          "command": "tableView.clearVariables",
          "when": "view == tableView.variablesView",
          "group": "navigation@3"
        }
      ],
      "debug/variables/context": [
        {
          "command": "table-view.viewAsTable",
          "group": "inline"
        }
      ]
    },
    "views": {
      "debug": [
        {
          "type": "webview",
          "id": "tableView.variablesView",
          "name": "Variables",
          "icon": "$(eye)",
          "when": "inDebugMode",
          "weight": 100
        }
      ]
    },
    "configuration": {
      "title": "Table View",
      "properties": {
        "tableView.chunkSize": {
          "type": "number",
          "default": 100,
          "description": "Number of rows to fetch per chunk when streaming table data."
        },
        "tableView.saveVariablesScope": {
          "type": "string",
          "enum": ["workspace", "global"],
          "default": "workspace",
          "description": "Scope to save watch variables in. 'workspace' will save variables per workspace, 'global' will save them globally."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.0.0"
  }
}