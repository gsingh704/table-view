{
  "name": "table-view",
  "displayName": "Table View",
  "description": "View 2D arrays in Table format",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "table-view.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "table-view.viewAsTable",
        "title": "View as Table",
        "icon": "$(table)"
      }
    ],
    "menus": {
      "debug/variables/context": [
        {
          "command": "table-view.viewAsTable",
          "group": "inline"
        }
      ]
    },
    "viewsContainers": {
      "panel": [
        {
          "id": "tableView-panel",
          "title": "Table View",
          "icon": "$(table)"
        }
      ]
    },
    "views": {
      "tableView-panel": [
        {
          "type": "webview",
          "id": "tableView.bottomView",
          "name": "Data Table",
          "icon": "$(table)"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.107.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}